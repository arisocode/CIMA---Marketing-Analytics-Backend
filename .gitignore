# ========================
# OTROS ÚTILES
# ========================

.env
*.yml
*.properties

!docker-compose.yml

# GitHub Actions workflows must be versioned even though other YAML files are local-only.
!.github/
!.github/workflows/
!.github/workflows/*.yml

# Maven Wrapper metadata is required for ./mvnw in CI.
!.mvn/
!.mvn/wrapper/
!.mvn/wrapper/maven-wrapper.properties

# Spring Boot application defaults are part of the service contract.
!src/main/resources/*.properties
